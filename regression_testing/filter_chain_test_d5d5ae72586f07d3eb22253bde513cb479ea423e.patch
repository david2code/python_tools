+void addTraceInfoToHeader(HeaderContext& context, std::string trace_info) {
+  auto trace_value = context.headers().get("Header-To-Trace");
+  if (trace_value.empty()) {
+    context.headers().add("Header-To-Trace", trace_info);
+  } else {
+    std::string modified_trace_value(trace_value);
+    modified_trace_value.append("_");
+    modified_trace_value.append(trace_info);
+    context.headers().set("Header-To-Trace", modified_trace_value);
+  }
+}
+
+
+HeaderStatus Plugin::onRequestHeader(HeaderContext& context) {
+  LOG(error, "onRequestHeader, end_stream: {}", !context.hasBody());
+#if TEST_MODE == MODE_CONTINUE
+  // 测试对 headers 进行增删改
+  modifyHeader(context, "_plugin_modified_onDecodeHeader_Continue");
+  return HeaderStatus::Continue;
+#elif TEST_MODE == MODE_DECODE_HEADER_DIRECT_RESPONSE
+  std::unique_ptr<SrhinoPluginFramework::HeaderMap> header = context.headers().create();
+  header->add("content-type", "text/plain");
+  context.setDirectResponse(Utility::HttpCode::Forbidden, std::move(header),
+                            std::move("DirectResponse onDecodeHeader"));
+  return HeaderStatus::DirectResponse;
+#elif TEST_MODE == MODE_DECODE_HEADER_BREAK || (TEST_MODE >= MODE_DECODE_DATA_WAIT_FOR_BODY && TEST_MODE <= MODE_DECODE_DATA_PAUSE_THEN_DIRECT_RESPONSE)
+  // 将 headers的修改延迟到 onRequestBody
+  request_header_ = &context;
+  context.setBreakBody(false);
+  return HeaderStatus::Break;
+// 配合 decode data 测试
+#elif TEST_MODE == MODE_DECODE_HEADER_PAUSE_THEN_CONTINUE
+  // 执行异步调用
+  timer_ = context.createTimer(std::chrono::milliseconds(500), [&](Timer& timer) {
+    modifyHeader(context, std::string("_plugin_modified_onDecodeHeader_Pause_then_Continue"));
+    context.continued();
+    return false;
+  }, false);
+  return HeaderStatus::Pause;
+#elif TEST_MODE == MODE_DECODE_HEADER_PAUSE_THEN_DIRECT_RESPONSE
+  // 执行异步调用
+  timer_ = context.createTimer(std::chrono::milliseconds(500), [&](Timer& timer) {
+    std::unique_ptr<SrhinoPluginFramework::HeaderMap> header = context.headers().create();
+    header->add("content-type", "text/plain");
+    context.setDirectResponse(Utility::HttpCode::Forbidden, std::move(header),
+                              std::move("DirectResponse onDecodeHeader"));
+    return false;
+  }, false);
+  return HeaderStatus::Pause;
+
+#elif TEST_MODE == MODE_PLUGIN_ITERATIVE_CONTINUE_TEST
+  LOG(error, "h2");
+  addTraceInfoToHeader(context, std::string("h2"));
+  return HeaderStatus::Continue;
+#elif TEST_MODE == MODE_PLUGIN_ITERATIVE_STOPITERATION_TEST
+  LOG(error, "h2");
+  addTraceInfoToHeader(context, std::string("h2"));
+  request_header_ = &context;
+  context.setBreakBody(false);
+  return HeaderStatus::Break;
+
+#else
+  return HeaderStatus::Continue;
+#endif
+}
